rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Blanket deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }

    // Chats persistence rules
    match /chats/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User profile and settings
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow subcollections for users if any
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Supporting legacy collections if needed (server-side admin access bypasses these anyway)
    match /prompts/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /analytics/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
